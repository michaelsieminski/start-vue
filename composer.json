{
	"$schema": "https://getcomposer.org/schema.json",
	"name": "michaelsieminski/kanbane-app",
	"type": "project",
	"description": "Kanbane is your AI-powered personal project manager with voice, smart chat, Kanban board, and docs - all deeply integrated to conquer ambitious projects without overwhelm.",
	"keywords": [],
	"license": "",
	"require": {
		"php": "^8.4",
		"inertiajs/inertia-laravel": "v2.0.14",
		"laravel/framework": "12.42.0",
		"laravel/tinker": "2.10.2"
	},
	"require-dev": {
		"fakerphp/faker": "1.24.1",
		"laravel/pail": "1.2.4",
		"laravel/pint": "1.26.0",
		"mockery/mockery": "1.6.12",
		"nunomaduro/collision": "8.8.3",
		"pestphp/pest": "4.1.6",
		"pestphp/pest-plugin-laravel": "4.0.0",
		"rector/rector": "2.2.14"
	},
	"autoload": {
		"psr-4": {
			"App\\": "app/",
			"Database\\Factories\\": "database/factories/",
			"Database\\Seeders\\": "database/seeders/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Tests\\": "tests/"
		}
	},
	"scripts": {
		"test": ["@php artisan config:clear --ansi", "@php artisan test"],
		"format": ["rector && pint --parallel && bun format"],
		"post-autoload-dump": [
			"Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
			"@php artisan package:discover --ansi"
		],
		"post-update-cmd": [
			"@php artisan vendor:publish --tag=laravel-assets --ansi --force"
		],
		"post-root-package-install": [
			"@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
		],
		"post-create-project-cmd": [
			"@php artisan key:generate --ansi",
			"@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
			"@php artisan migrate --graceful --ansi"
		],
		"pre-package-uninstall": [
			"Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
		]
	},
	"extra": {
		"laravel": {
			"dont-discover": []
		}
	},
	"config": {
		"optimize-autoloader": true,
		"preferred-install": "dist",
		"sort-packages": true,
		"allow-plugins": {
			"pestphp/pest-plugin": true,
			"php-http/discovery": true
		}
	},
	"minimum-stability": "stable",
	"prefer-stable": true
}
